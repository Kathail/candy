# Required in all environments
SECRET_KEY=generate-a-strong-random-key-here

# Required on first run (creates admin user)
ADMIN_PASSWORD=change-me-strong-password-12-chars

# Set to "development" for debug mode (never in production)
FLASK_ENV=development

# Database (defaults to SQLite for development)
# DATABASE_URL=postgresql://user:pass@host:5432/candy_route

# Optional
# FLASK_HOST=127.0.0.1
# FLASK_PORT=5000
